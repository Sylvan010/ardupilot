MCU STM32F4xx STM32F405xx
APJ_BOARD_ID 5055
OSCILLATOR_HZ 8000000
FLASH_SIZE_KB 1024
FLASH_RESERVE_START_KB 48
define HAL_BOOTLOADER_BUILD 1

PA11 OTG_FS_DM OTG1
PA12 OTG_FS_DP OTG1

PC15 LED0 OUTPUT LOW
PC14 LED1 OUTPUT LOW

PA4  GYRO1_CS  CS OUTPUT HIGH
PB12 OSD1_CS   CS OUTPUT HIGH
PA15 FLASH1_CS CS OUTPUT HIGH
