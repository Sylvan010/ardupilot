# HAKRC-F405V2 production defaults
BATT_MONITOR 4
BATT_VOLT_PIN 11
BATT_CURR_PIN 13
BATT_VOLT_MULT 10.0
BATT_AMP_PERVLT 100.0

OSD_TYPE 1

NTF_LED_TYPES 257
NTF_LED_BRIGHT 2

LOG_BACKEND_TYPE 1

RELAY1_PIN -1
RELAY2_PIN -1
RELAY3_PIN -1
RELAY4_PIN -1

FS_GCS_ENABLE 0
FS_OPTIONS 1

RC5_OPTION 153
RC7_OPTION 65
