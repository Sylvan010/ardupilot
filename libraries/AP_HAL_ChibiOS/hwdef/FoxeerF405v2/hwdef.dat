# hwdef/FoxeerF405v2: remap pins for HAKRC F405 V2 board
# Reallocated resources from FoxeerF405v2 layout to match HAKRC F405 V2 hardware specification:
- Moved UART1 from PA9/PA10 to PB6/PB7 to free up pins for motors
- Assigned MOTOR 4 and MOTOR 5 to PA9 and PA10
- Moved Beeper to PC13 and Status LEDs to PC14/PC15
- Remapped SPI3 bus (PC10/PC11/PB5) and adjusted OSD_CS (PB12) / FLASH_CS (A15)
- Updated ADC pins for battery voltage (PC1) and current (PC3)
# for FOXEERF405V2 hardware.
# thanks to betaflight for pin information

# MCU class and specific type
MCU STM32F4xx STM32F405xx

# board ID. See Tools/AP_Bootloader/board_types.txt
APJ_BOARD_ID AP_HW_FOXEERF405_V2

# crystal frequency, setup to use external oscillator
OSCILLATOR_HZ 8000000

FLASH_SIZE_KB 1024

# bootloader takes first sector
FLASH_RESERVE_START_KB 48

define HAL_STORAGE_SIZE 16384
define STORAGE_FLASH_PAGE 1

STM32_ST_USE_TIMER 5

# SPI devices

# SPI1
PA5 SPI1_SCK SPI1
PA6 SPI1_MISO SPI1
PA7 SPI1_MOSI SPI1

# SPI2 (Перенесены MISO/MOSI)
PB13 SPI2_SCK SPI2
PB14 SPI2_MISO SPI2
PB15 SPI2_MOSI SPI2

# SPI3 (Полностью перенесен на новые пины)
PC10 SPI3_SCK SPI3
PC11 SPI3_MISO SPI3
PB5  SPI3_MOSI SPI3

# Чип-селекты устройств (CS)
PA4  GYRO_CS CS
PC4  GYRO_EXTI INPUT
A15  FLASH_CS CS
PB12 OSD_CS CS

# Пищалка (Beeper)
PC13 BUZZER OUTPUT LOW

# SERIAL ports
SERIAL_ORDER OTG1 USART1 USART2 USART3 UART4 UART5 USART6
# PA10 IO-debug-console
PA11 OTG_FS_DM OTG1
PA12 OTG_FS_DP OTG1

# UART1 (Перенесен на PB6/PB7)
PB6 USART1_TX USART1
PB7 USART1_RX USART1
define DEFAULT_SERIAL1_PROTOCOL SerialProtocol_ESCTelemetry

# UART2 (Остался на PA2/PA3)
PA2 USART2_TX USART2
PA3 USART2_RX USART2
define DEFAULT_SERIAL2_PROTOCOL SerialProtocol_RCIN

# UART3 (Перенесен на PB10/PB11)
PB10 USART3_TX USART3
PB11 USART3_RX USART3
define DEFAULT_SERIAL3_PROTOCOL SerialProtocol_Tramp

# UART4 (Остался на PA0/PA1)
PA0 UART4_TX UART4
PA1 UART4_RX UART4
define DEFAULT_SERIAL4_PROTOCOL SerialProtocol_MSP_DisplayPort

# UART5 (Остался на PC12/PD2)
PC12 UART5_TX UART5
PD2  UART5_RX UART5
define DEFAULT_SERIAL5_PROTOCOL SerialProtocol_GPS

# UART6 (Остался на PC6/PC7)
PC6 USART6_TX USART6
PC7 USART6_RX USART6

# I2C ports
I2C_ORDER I2C1
# I2C1 (Остался на PB8/PB9)
PB8 I2C1_SCL I2C1
PB9 I2C1_SDA I2C1

# Servos
PB14 CAMERA1 OUTPUT GPIO(71) LOW
define RELAY3_PIN_DEFAULT 71

# ADC ports

# ADC1
PC1 BATT_VOLT_SENS ADC1_CH11
define HAL_BATT_VOLT_PIN 10
define HAL_BATT_VOLT_SCALE 11.0
PC3 BATT_CURRENT_SENS ADC1_CH13
define HAL_BATT_CURR_PIN 11
define HAL_BATT_CURR_SCALE 142.9
PC5 RSSI_IN ADC1_CH15
define BOARD_RSSI_ANA_PIN 15
define HAL_BATT_MONITOR_DEFAULT 4

# MOTORS
PC8  TIM3_CH3  PWM(1) GPIO(50)          # M1
PC9  TIM3_CH4  PWM(2) GPIO(51)          # M2
PA8  TIM1_CH1  PWM(3) GPIO(52)          # M3
PA9  TIM1_CH2  PWM(4) GPIO(53)          # M4
PA10 TIM1_CH3  PWM(5) GPIO(54)          # M5
PB4  TIM3_CH1  PWM(6) GPIO(55)          # M6
PB0  TIM3_CH3  PWM(7) GPIO(56)          # M7
PB1  TIM3_CH4  PWM(8) GPIO(57)          # M8

PB3 TIM2_CH2 TIM4 PWM(9) GPIO(58)       # LED

# Servos
PB1 TIM3_CH4 TIM3 PWM(10) GPIO(70) NODMA # S1 / M10
PB0 TIM3_CH3 TIM3 PWM(11) GPIO(72) NODMA # S2 / M11

# LEDs
define AP_NOTIFY_GPIO_LED_2_ENABLED 1

PC15 LED0 OUTPUT LOW GPIO(90)
define HAL_GPIO_A_LED_PIN 90

PC14 LED1 OUTPUT LOW GPIO(91)
define HAL_GPIO_B_LED_PIN 91

# Dataflash setup
SPIDEV dataflash SPI2 DEVID1 FLASH1_CS     MODE3 104*MHZ 104*MHZ

define HAL_LOGGING_DATAFLASH_ENABLED 1

# OSD setup
SPIDEV osd SPI3 DEVID1 OSD1_CS   MODE0  10*MHZ  10*MHZ

define OSD_ENABLED 1
define HAL_OSD_TYPE_DEFAULT 1
ROMFS_WILDCARD libraries/AP_OSD/fonts/font*.bin

# Barometer setup
BARO DPS310 I2C:0:0x76
BARO BMP280 I2C:0:0x76
BARO SPL06  I2C:0:0x76

# IMU setup

# IMU setup
SPIDEV imu1   SPI1 DEVID1 GYRO1_CS   MODE3   1*MHZ   8*MHZ

IMU Invensensev3 SPI:imu1 ROTATION_PITCH_180_YAW_90

# no built-in compass, but probe the i2c bus for all possible
# external compass types
define ALLOW_ARM_NO_COMPASS
define AP_COMPASS_PROBING_ENABLED 1
define HAL_I2C_INTERNAL_MASK 0
define HAL_COMPASS_AUTO_ROT_DEFAULT 2
define HAL_DEFAULT_INS_FAST_SAMPLE 3
# Motor order implies Betaflight/X for standard ESCs
define HAL_FRAME_TYPE_DEFAULT 12

include ../include/minimize_fpv_osd.inc
