# hwdef-bl.dat для HAKRC-F405V2 (ID FoxeerF405v2)

MCU STM32F4xx STM32F405xx
APJ_BOARD_ID AP_HW_FOXEERF405_V2

OSCILLATOR_HZ 8000000
FLASH_SIZE_KB 1024

PA11 OTG_FS_DM OTG1
PA12 OTG_FS_DP OTG1

PA4  GYRO1_CS  CS OUTPUT HIGH
PB12 OSD1_CS   CS OUTPUT HIGH
PA15 FLASH1_CS CS OUTPUT HIGH

PC15 LED_BOOTLOADER OUTPUT LOW
define HAL_LED_ON 0
