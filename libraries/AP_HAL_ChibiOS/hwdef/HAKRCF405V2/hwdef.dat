# hwdef.dat для HAKRC F405 V2 (с подменой через speedybeef4v3)

# Определение микроконтроллера
MCU STM32F405 STM32F405xx

# Настройка частоты кварца и генератора
define STM32_ST_USE_TIMER 5
OSCILLATOR_HZ 8000000

# Подключаем файл параметров по умолчанию, который мы подменили
include defaults.parm

# Распределение памяти Flash под загрузчик и прошивку
FLASH_SIZE_KB 1024
FLASH_RESERVE_START_KB 64

# Порядок и конфигурация UART портов (зависит от схемы HAKRC V2)
# UART1 - RX1/TX1 (Обычно под приемник)
PA10 USART1_RX USART1
PA9  USART1_TX USART1

# UART2 - RX2/TX2
PA3  USART2_RX USART2
PA2  USART2_TX USART2

# UART3 - RX3/TX3 (Обычно DJI / GPS)
PB11 USART3_RX USART3
PB10 USART3_TX USART3

# UART4 - RX4/TX4
PC11 UART4_RX UART4
PC10 UART4_TX UART4

# UART6 - RX6/TX6 (Телеметрия)
PC7  USART6_RX USART6
PC6  USART6_TX USART6

# Настройка портов I2C (для внешнего компаса на GPS)
I2C_ORDER I2C1
PB8 I2C1_SCL I2C1
PB9 I2C1_SDA I2C1

# Настройка шины SPI1 для гироскопа/акселерометра
PA5 SPI1_SCK SPI1
PA6 SPI1_MISO SPI1
PA7 SPI1_MOSI SPI1

# Настройка шины SPI3 для OSD (AT7456E) и Flash-памяти Blackbox
PB3 SPI3_SCK SPI3
PB4 SPI3_MISO SPI3
PB5 SPI3_MOSI SPI3

# Выборы чипов (CS) для SPI устройств
PA4  MPU6000_CS CS PIN_LOW
PC12 OSD_CS CS PIN_LOW
PB12 FLASH_CS CS PIN_LOW

# Конфигурация датчиков (IMU) на шине SPI1
SPIDEV mpu6000 SPI1 CS MPU6000_CS MODE3 1*MHZ 8*MHZ
IMU MPU6000 SPI:mpu6000 ROTATION_ROLL_180_YAW_90

# Конфигурация барометра (определяется на шине I2C1 автоматическим сканированием)
BARO BMP280 I2C:0:0x76

# Конфигурация чипа OSD
SPIDEV osd SPI3 CS OSD_CS MODE0 10*MHZ 10*MHZ
OSD AT7456E SPI:osd

# Конфигурация Flash памяти для логов (Blackbox)
SPIDEV flash SPI3 CS FLASH_CS MODE3 32*MHZ 32*MHZ
MAIN_FLASH_HOLD_PIN PA15
define HAL_STORAGE_SIZE 16384

# Выходы моторов (PWM / DShot)
PB0  TIM3_CH3 PWM1 MOTOR1
PB1  TIM3_CH4 PWM2 MOTOR2
PA0  TIM5_CH1 PWM3 MOTOR3
PA1  TIM5_CH2 PWM4 MOTOR4

# Аналоговые пины (Датчики тока и напряжения)
PC2 VOLTAGE_SENS ADC1 SCALE(1)
PC3 CURRENT_SENS ADC1 SCALE(1)

define HAL_BATT_VOLT_PIN 12
define HAL_BATT_CURR_PIN 13
define HAL_BATT_VOLT_SCALE 11.0
define HAL_BATT_CURR_SCALE 27.5

# Светодиоды и пищалка
PA13 LED OUTPUT HIGH
PA14 LED2 OUTPUT HIGH
PB2  BUZZER OUTPUT PIN_LOW
