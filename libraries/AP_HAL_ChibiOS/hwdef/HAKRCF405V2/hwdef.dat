# hw definition file for processing by chibios_hwdef.py
# Target: FoxeerF405v2 - Custom Modified for HAKRC-F405V2 Resource Mapping
# All original ArduPilot low-level configurations, DMA and timers are strictly preserved.

MCU STM32F405 MCU_FAST_CLOCK

# Системне тактування (8MHz кварц)
define CONFIG_HAL_BOARD_SUBTYPE HAL_BOARD_SUBTYPE_CHIBIOS_HWDEF
define STM32_HSE_ENABLED TRUE
define STM32_HSECLK 8000000

ENV_SIZE 16k

# USB VCP Конфігурація
PA11 OTG_FS_DM OTG1
PA12 OTG_FS_DP OTG1

define USB_VENDOR 0x0483 # STMicroelectronics
define USB_PRODUCT_ID 0x5740
define USB_STRING_MANUFACTURER "Foxeer"
define USB_STRING_PRODUCT "FoxeerF405v2"

# Порядок SERIAL портів у Mission Planner
SERIAL_ORDER OTG1 USART1 USART2 USART3 UART4 UART5 USART6

# --- UART Mapping (Мапінг HAKRC) ---
PB6  USART1_TX USART1
PB7  USART1_RX USART1

PA2  USART2_TX USART2
PA3  USART2_RX USART2
PC0  SBUS_INVERT OUTPUT LOW

PB10 USART3_TX USART3
PB11 USART3_RX USART3

PA0  UART4_TX UART4
PA1  UART4_RX UART4

PC12 UART5_TX UART5
PD2  UART5_RX UART5

PC6  USART6_TX USART6
PC7  USART6_RX USART6

# Шина I2C1 (Для зовнішнього компаса та барометра)
PB8 I2C1_SCL I2C1
PB9 I2C1_SDA I2C1

# SPI1: Головний сенсор положення (IMU Гіроскоп / Акселерометр)
PA5 SPI1_SCK SPI1
PA6 SPI1_MISO SPI1
PA7 SPI1_MOSI SPI1
PA4 GYRO_CS CS

# SPI2: Аналогове OSD MAX7456 (Точковий мапінг HAKRC)
PB13 SPI2_SCK SPI2   # 10 ножка MAX7456
PB14 SPI2_MISO SPI2  # 11 ножка MAX7456
PB15 SPI2_MOSI SPI2  # 9 ножка MAX7456
PB12 OSD_CS CS       # 8 ножка MAX7456

# SPI3: Бортова Flash Blackbox пам'ять W25Q128 (Точковий мапінг HAKRC)
PC10 SPI3_SCK SPI3   # 6 ножка пам'яті
PC11 SPI3_MISO SPI3  # 2 ножка пам'яті
PB5  SPI3_MOSI SPI3  # 5 ножка пам'яті
PA15 FLASH_CS CS     # 1 ножка пам'яті (CS)

# Реєстрація пристроїв на SPI шинах
SPIDEV gyro1 SPI1 SPEED_2M SPEED_8M GYRO_CS LOW
SPIDEV osd   SPI2 SPEED_4M SPEED_4M OSD_CS   LOW
SPIDEV flash SPI3 SPEED_4M SPEED_8M FLASH_CS LOW

# EXTI лінія апаратного переривання гіроскопа
PC4 MPU6000_DRDY INPUT

# Драйвери сенсорів польоту з орієнтацією CW90 відповідно до Betaflight
IMU Invensense SPI:gyro1 ROTATION_YAW_90
IMU BMI270 SPI:gyro1 ROTATION_YAW_90

# Барометри на шині I2C1
BARO BMP280 I2C:0:0x76
BARO DPS310 I2C:0:0x76

# Логування (Вмикаємо підтримку Dataflash, розмір визначиться автоматично через SPIDEV)
define HAL_LOGGING_DATAFLASH

# --- Конфігурація АЦП датчиків напруги та струму (HAKRC) ---
PC1 ADC_BAT VOLTAGE_ADC
PC3 ADC_CURR CURRENT_ADC
define HAL_BATT_VOLT_PIN 1
define HAL_BATT_CURR_PIN 3
define HAL_BATT_VOLT_SCALE 10.0
define HAL_BATT_CURR_SCALE 100.0

# --- Статусні світлодіоди та бузер (HAKRC) ---
PC14 LED1 OUTPUT HIGH
PC15 LED2 OUTPUT HIGH
define HAL_LED_ON 0

PC13 BUZZER OUTPUT HIGH
define HAL_BUZZER_ON 0

# --- Карта апаратних таймерів для PWM виходів двигунів (Строго за твоїм дампом) ---
PC8  TIM8_CH3  PWM1 Motor
PC9  TIM8_CH4  PWM2 Motor
PA8  TIM1_CH1  PWM3 Motor
PA9  TIM1_CH2  PWM4 Motor
PB0  TIM3_CH3  PWM5 Motor
PB1  TIM3_CH4  PWM6 Motor
PA10 TIM1_CH3  PWM7 Motor
PB4  TIM3_CH1  PWM8 Motor
PB3  TIM2_CH2  PWM9 Servo

# === СЛУЖБОВІ НАЛАШТУВАННЯ ТА КАРТИ DMA (ОРИГІНАЛЬНІ ВІД FOXEER) ===
DMA_PRIORITY SPI1_RX SPI1_TX SPI2_RX SPI2_TX SPI3_RX SPI3_TX TIM* USART1* USART2* USART3* UART4* UART5* USART6*
DMA_NOSHARE SPI1_RX SPI1_TX ADC3
define STM32_ST_USE_TIMER 5

# Оригінальний ідентифікатор плати FoxeerF405v2
define ROMFS_BOOTLOADER_BOARD_ID 1056
define APJ_BOARD_ID 1056
