MCU STM32F4xx STM32F405xx

FLASH_RESERVE_START_KB 64
FLASH_SIZE_KB 1024

STORAGE_FLASH_PAGE 1
define HAL_STORAGE_SIZE 15360

APJ_BOARD_ID AP_HW_MatekF405_TE

define STM32_ST_USE_TIMER 5
define CH_CFG_ST_RESOLUTION 32

OSCILLATOR_HZ 8000000

define AP_NOTIFY_GPIO_LED_2_ENABLED 1
PC15 LED0 OUTPUT LOW GPIO(90)
PC14 LED1 OUTPUT LOW GPIO(91)
define HAL_GPIO_A_LED_PIN 90
define HAL_GPIO_B_LED_PIN 91

PC8  TIM8_CH3   TIM8  PWM(1)  GPIO(50)
PC9  TIM8_CH4   TIM8  PWM(2)  GPIO(51)

PA8  TIM1_CH1   TIM1  PWM(3)  GPIO(52)
PA9  TIM1_CH2   TIM1  PWM(4)  GPIO(53)

PA10 OUTPUT LOW GPIO(54)

PB4  TIM3_CH1   TIM3  PWM(6)  GPIO(55)

define HAL_SERVO_DEFAULT_RATE 50

PC13 OUTPUT LOW GPIO(32) ALARM BEEPER_INVERTED

PC2  PINIO1 OUTPUT GPIO(81) LOW
PC5  PINIO2 OUTPUT GPIO(82) LOW
define PINIO1_BOX 40
define PINIO2_BOX 41

PA5  SPI1_SCK  SPI1
PA6  SPI1_MISO SPI1
PA7  SPI1_MOSI SPI1

PA4  GYRO_1_CS CS
PC4  GYRO_1_EXTI_PIN EXTI

SPIDEV icm42688 SPI1 DEVID1 GYRO_1_CS MODE3 2*MHZ 8*MHZ
IMU Invensensev3 SPI:icm42688 ROTATION_YAW_90
define HAL_DEFAULT_INS_FAST_SAMPLE 1

PB13 SPI2_SCK  SPI2
PB14 SPI2_MISO SPI2
PB15 SPI2_MOSI SPI2

PB12 OSD_CS CS

SPIDEV osd SPI2 DEVID2 OSD_CS MODE0 10*MHZ 10*MHZ
define OSD_ENABLED 1
define HAL_OSD_TYPE_DEFAULT 1
ROMFS_WILDCARD libraries/AP_OSD/fonts/font0.bin

PC10 SPI3_SCK  SPI3
PC11 SPI3_MISO SPI3
PB5  SPI3_MOSI SPI3

PA15 FLASH_CS CS

SPIDEV dataflash SPI3 DEVID1 FLASH_CS MODE3 32*MHZ 32*MHZ
define HAL_LOGGING_DATAFLASH_ENABLED 1
define HAL_OS_FATFS_IO 1

I2C_ORDER I2C1

PB8 I2C1_SCL I2C1
PB9 I2C1_SDA I2C1

define HAL_I2C_INTERNAL_MASK 0
define ALLOW_ARM_NO_COMPASS 1
define AP_COMPASS_PROBING_ENABLED 1
define HAL_COMPASS_AUTO_ROT_DEFAULT 2

BARO SPL06 I2C:0:0x76
define AP_BARO_BACKEND_DEFAULT_ENABLED 1

SERIAL_ORDER OTG1 USART1 USART2 USART3 UART4 UART5 USART6

PA11 OTG_FS_DM OTG1
PA12 OTG_FS_DP OTG1

PB6  USART1_TX USART1 
PB7  USART1_RX USART1

PA2  USART2_TX USART2 
PA3  USART2_RX USART2 ALT(1)
PA3  TIM9_CH2 TIM9 RCININT PULLDOWN LOW
PC0  INVERTER_PIN_UART2 INPUT PULLUP

PB10 USART3_TX USART3 NODMA
PB11 USART3_RX USART3 NODMA

PA0  UART4_TX UART4 NODMA
PA1  UART4_RX UART4 NODMA

PC12 UART5_TX UART5 NODMA
PD2  UART5_RX UART5 NODMA

PC6  USART6_TX USART6
PC7  USART6_RX USART6 NODMA

PC1 BATT_VOLTAGE_SENS ADC1 SCALE(1)
PC3 BATT_CURRENT_SENS ADC1 SCALE(1)

define HAL_BATT_MONITOR_DEFAULT 4
define HAL_BATT_VOLT_PIN 11
define HAL_BATT_CURR_PIN 13

define HAL_BATT_VOLT_SCALE 21.0
define HAL_BATT_CURR_SCALE 66.7

DMA_PRIORITY ADC1 SPI1* SPI2* SPI3* TIM1* TIM8* TIM3* TIM4* USART1* USART2*

include ../include/minimize_fpv_osd.inc
include ../include/no_bootloader_DFU.inc
define HAL_MINIMIZE_FEATURES 1
define HAL_PARACHUTE_ENABLED 0
define HAL_RUNCAM_ENABLED 0
define HAL_BUTTON_ENABLED 0
